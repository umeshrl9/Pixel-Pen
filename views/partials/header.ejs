<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>
    <%= typeof title !=="undefined" ? title : "Pixel & Pen - Your personal blogging app" %>
  </title>

  <link rel="icon" href="/images/icons8-pen-32.png" type="image/png">
  <link rel="stylesheet" href="/styles/headerStyle.css">
  <link rel="stylesheet" href="/styles/indexStyle.css">
  <link rel="stylesheet" href="/styles/footerStyle.css">
  <link rel="stylesheet" href="/styles/authStyle.css">
  <% if (typeof css !=="undefined" && css.length) { %>
    <% css.forEach(file=> { %>
      <link rel="stylesheet" href="<%= file %>">
      <% }) %>
        <% } %>

          <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
          <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
          <link rel="preconnect" href="https://fonts.googleapis.com">
          <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
          <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Playfair+Display:wght@600;700&display=swap"
            rel="stylesheet">
          <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;800&display=swap" rel="stylesheet">
</head>

<body>

  <header class="site-header">
    <div class="container header-inner">

      <a href="/" class="brand">
        Pixel<span>&</span>Pen
      </a>

      <% if (currentUser) { %>
        <div class="profile-menu">

          <button class="profile-btn" onclick="toggleMenu()">
            <% if (currentUser.profile_picture) { %>
              <img src="<%= currentUser.profile_picture %>" class="avatar">
              <% } else { %>
                <i class="bi bi-person-circle avatar-icon"></i>
                <% } %>
          </button>

          <div class="dropdown-menu" id="profileDropdown">

            <a href="/profile">
              <i class="bi bi-person"></i>
              Your Profile
            </a>

            <a href="/logout">
              <i class="bi bi-box-arrow-right"></i>
              Logout
            </a>

            <div class="dropdown-divider"></div>

            <form action="/delete-account" method="POST">
              <button type="submit" class="delete-btn">
                <i class="bi bi-trash"></i>
                Delete Account
              </button>
            </form>

          </div>
        </div>
        <% } %>

    </div>
  </header>

  <script>
    function toggleMenu() {
      const menu = document.getElementById("profileDropdown");
      menu.style.display = menu.style.display === "flex" ? "none" : "flex";
    }

    window.addEventListener("click", function (e) {
      if (!e.target.closest(".profile-menu")) {
        const menu = document.getElementById("profileDropdown");
        if (menu) menu.style.display = "none";
      }
    });
  </script>