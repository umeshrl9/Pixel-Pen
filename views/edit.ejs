<%- include("partials/header", {
  title: "Edit post | Pixel & Pen",
  css: ["/styles/editBlog.css"]
}) %>

<section class="editor-page">
  <div class="editor-inner">

    <div class="editor-header">
      <h1>Edit post</h1>
      <p>Refine your thoughts and make them clearer.</p>
    </div>

    <form action="/edit/<%= blog.id %>" method="POST" class="editor-form">

      <!-- Title -->
      <div class="form-group">
        <label for="title">Title</label>
        <input
          id="title"
          type="text"
          name="title"
          value="<%= blog.title %>"
          required
        />
      </div>

      <!-- Content -->
      <div class="form-group">
        <label for="content">Content</label>
        <textarea
          id="content"
          name="content"
          rows="10"
          required
        ><%= blog.content %></textarea>
      </div>

      <!-- Actions -->
      <div class="editor-actions">
        <button type="submit" class="btn-primary">
          Save changes
        </button>

        <a href="/main" class="btn-secondary">
          Cancel
        </a>
      </div>

    </form>

  </div>
</section>

<%- include("partials/footer") %>
