<%- include("partials/header", { title: "Edit Profile | Pixel & Pen", css: ["/styles/mainPage.css", "/styles/profile.css"] }) %>

<section class="dashboard">
  <div class="dashboard-inner">

    <!-- Header -->
    <div class="dashboard-header">
      <div>
        <h1>Edit profile</h1>
        <p>Update your personal information.</p>
      </div>

      <div class="dashboard-actions">
        <a href="/profile" class="btn-secondary">Back to profile</a>
      </div>
    </div>

    <div class="edit-profile-card blog-card">

      <form action="/edit-profile" method="POST" enctype="multipart/form-data">

        <!-- PROFILE IMAGE -->
        <div class="edit-avatar">

          <img 
            src="<%= user.profile_picture || '/images/avatar-default.svg' %>" 
            class="edit-avatar-img"
          >

          <label class="avatar-upload">
            Change picture
            <input type="file" name="profile_picture">
          </label>

        </div>


        <!-- NAME -->
        <div class="form-group">
          <label>Name</label>
          <input 
            type="text"
            name="name"
            value="<%= user.name || '' %>"
            placeholder="Your name"
          >
        </div>


        <!-- BIO -->
        <div class="form-group">
          <label>Bio</label>
          <textarea 
            name="bio"
            rows="3"
            placeholder="Write a short bio..."
          ><%= user.bio || '' %></textarea>
        </div>


        <!-- WEBSITE -->
        <div class="form-group">
          <label>Website</label>
          <input 
            type="url"
            name="website"
            value="<%= user.website || '' %>"
            placeholder="https://yourwebsite.com"
          >
        </div>


        <!-- LOCATION -->
        <div class="form-group">
          <label>Location</label>
          <input 
            type="text"
            name="location"
            value="<%= user.location || '' %>"
            placeholder="City, Country"
          >
        </div>


        <!-- ACTIONS -->
        <div class="form-actions">
          <button class="btn-primary">Save changes</button>
          <a href="/profile" class="btn-secondary">Cancel</a>
        </div>

      </form>

    </div>

  </div>
</section>

<%- include("partials/footer") %>