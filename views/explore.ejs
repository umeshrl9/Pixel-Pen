<%- include("partials/header", { title: "Explore | Pixel & Pen" , css: ["/styles/mainPage.css"] }) %>

    <section class="dashboard">
        <div class="dashboard-inner">

            <!-- Header -->
            <div class="dashboard-header">
                <div>
                    <h1>Explore</h1>
                    <p>Discover blogs shared by the community.</p>
                </div>
            </div>

            <!-- Search (Backend) -->
            <form action="/search" method="GET" class="search-bar">
                <input type="text" name="q" placeholder="Search blogs..."
                    value="<%= typeof query !== 'undefined' ? query : '' %>">
            </form>

            <% if (!blogs || blogs.length===0) { %>

                <div class="empty-state">
                    <i class="bi bi-journal-text"></i>
                    <h3>No blogs found</h3>
                    <p>Try searching for something else.</p>
                </div>

                <% } else { %>

                    <div class="blog-list">

                        <% blogs.forEach(blog=> { %>

                            <article class="explore-card">

                                <!-- VOTES -->
                                <div class="vote-column">
                                    <button class="vote-btn upvote" data-id="<%= blog.id %>">
                                        <i class="bi bi-caret-up-fill"></i>
                                    </button>

                                    <span class="vote-score" data-id="<%= blog.id %>">
                                        <%= blog.score %>
                                    </span>

                                    <button class="vote-btn downvote" data-id="<%= blog.id %>">
                                        <i class="bi bi-caret-down-fill"></i>
                                    </button>

                                </div>


                                <!-- CONTENT -->
                                <div class="explore-content">

                                    <div class="post-meta">
                                        <img src="<%= blog.profile_picture || '/images/default-avatar.png' %>"
                                            class="avatar">
                                        <span class="username">
                                            <%= blog.username %>
                                        </span>
                                    </div>

                                    <h2>
                                        <a href="/blogs/<%= blog.id %>">
                                            <%= blog.title %>
                                        </a>
                                    </h2>

                                    <p class="excerpt">
                                        <%= blog.content.length> 260 ? blog.content.substring(0,260) + "..." :
                                            blog.content %>
                                    </p>

                                </div>

                            </article>

                            <% }) %>

                    </div>

                    <% } %>

        </div>
    </section>


    <script>

        /* Voting */

        const voteButtons = document.querySelectorAll(".vote-btn");

        voteButtons.forEach(btn => {

            btn.addEventListener("click", async () => {

                const blogId = btn.dataset.id;
                const voteType = btn.classList.contains("upvote") ? 1 : -1;

                const scoreEl = document.querySelector(`.vote-score[data-id="${blogId}"]`);
                let currentScore = parseInt(scoreEl.textContent);

                /* -- OPTIMISTIC UPDATE --- */

                scoreEl.textContent = currentScore + voteType;

                const column = btn.closest(".vote-column");
                const upBtn = column.querySelector(".upvote");
                const downBtn = column.querySelector(".downvote");

                if (voteType === 1) {
                    upBtn.classList.add("active-up");
                } else {
                    downBtn.classList.add("active-down");
                }

                /* --- SERVER REQUEST --- */



                try {

                    const res = await fetch("/vote", {
                        method: "POST",
                        headers: {
                            "Content-Type": "application/json"
                        },
                        body: JSON.stringify({
                            blogId,
                            voteType
                        })
                    });

                    if (!res.ok) {
                        throw new Error("Vote Failed");
                    }

                    const data = await res.json();

                    scoreEl.textContent = data.score;

                    upBtn.classList.remove("active-up");
                    downBtn.classList.remove("active-down");

                    if (data.userVote === 1) {
                        upBtn.classList.add("active-up");
                    }

                    if (data.userVote === -1) {
                        downBtn.classList.add("active-down");
                    }

                } catch (err) {
                    /* revert optimistic change */

                    scoreEl.textContent = currentScore;
                    upBtn.classList.remove("active-up");
                    downBtn.classList.remove("active-down");

                    console.error(err);
                }

            });

        });

    </script>

    <%- include("partials/footer") %>